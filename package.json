{
	"name": "@joshthomas/sveltekit-adapter-cloudflare",
	"version": "0.2.0",
	"description": "Fork of @sveltejs/adapter-cloudflare with support for scheduled, queue, and email handlers",
	"keywords": [
		"adapter",
		"cloudflare pages",
		"cloudflare workers",
		"deploy",
		"hosting",
		"svelte",
		"sveltekit"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/joshuadavidthomas/sveltekit-adapter-cloudflare.git"
	},
	"bugs": {
		"url": "https://github.com/joshuadavidthomas/sveltekit-adapter-cloudflare/issues"
	},
	"license": "MIT",
	"homepage": "https://github.com/joshuadavidthomas/sveltekit-adapter-cloudflare#readme",
	"publishConfig": {
		"access": "public"
	},
	"type": "module",
	"exports": {
		".": {
			"types": "./index.d.ts",
			"import": "./index.js"
		},
		"./package.json": "./package.json"
	},
	"types": "index.d.ts",
	"files": [
		"files",
		"index.js",
		"utils.js",
		"index.d.ts",
		"ambient.d.ts"
	],
	"scripts": {
		"build": "esbuild src/worker.js --bundle --outfile=files/worker.js --external:SERVER --external:MANIFEST --external:cloudflare:workers --format=esm",
		"lint": "prettier --check .",
		"format": "prettier --write .",
		"check": "tsc --skipLibCheck",
		"test:unit": "vitest run",
		"test:e2e": "pnpm build && pnpm -r --workspace-concurrency 1 --filter=\"./test/**\" test",
		"test": "pnpm test:unit && pnpm test:e2e",
		"prepack": "pnpm build"
	},
	"dependencies": {
		"@cloudflare/workers-types": "^4.20250507.0",
		"worktop": "0.8.0-next.18"
	},
	"devDependencies": {
		"@playwright/test": "^1.59.1",
		"@sveltejs/kit": "^2.57.1",
		"@types/node": "^25.6.0",
		"esbuild": "^0.28.0",
		"prettier": "^3.8.3",
		"typescript": "^6.0.3",
		"vitest": "^4.1.5"
	},
	"peerDependencies": {
		"@sveltejs/kit": "^2.0.0",
		"wrangler": "^4.0.0"
	}
}
